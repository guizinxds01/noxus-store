generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Float
  promoPrice  Float?
  category    String
  subcategory String?
  sizes       String
  colors      String?
  sku         String?
  description String
  imageUrl    String
  images      String?  // JSON array
  videoUrl    String?
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  badge       String?
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String?
  parentId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id         String   @id @default(uuid())
  imageUrl   String
  title      String?
  subtitle   String?
  buttonText String?
  buttonLink String?
  active     Boolean  @default(true)
  order      Int      @default(0)
  fit        String   @default("cover")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Settings {
  id            String   @id @default("global")
  logoUrl       String?
  faviconUrl    String?
  primaryColor  String   @default("#10B981")
  whatsapp      String   @default("5511948108764")
  whatsappMsg   String   @default("Olá, quero comprar o produto: [nome_do_produto]")
  instagram     String?
  tiktok        String?
  midBannerUrl    String?
  midBannerTitle  String?
  midBannerLink   String?
  updatedAt     DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
